@model EcommerceFullstackDesign.Models.Product

@{
    ViewData["Title"] = Model?.Name ?? "Product Details";
}

<div class="container mt-5">
    @if (Model != null)
    {
        <div class="row">
            <div class="col-md-6">
                <div class="product-image-container text-center p-4 bg-white rounded shadow-sm">
                    <img src="@(Model.ImageUrl ?? "/Image/bottle.png")"
                         class="img-fluid"
                         alt="@Model.Name"
                         style="max-height: 400px; object-fit: contain;" />
                </div>
            </div>

            <div class="col-md-6">
                <div class="product-details bg-white p-4 rounded shadow-sm">
                    <h2>@Model.Name</h2>

                    @if (Model.DiscountPrice.HasValue && Model.DiscountPrice < Model.Price)
                    {
                        <h4 class="text-danger">
                            $@Model.DiscountPrice.Value.ToString("0.00")
                            <small class="text-muted text-decoration-line-through ms-2">$@Model.Price.ToString("0.00")</small>
                        </h4>
                    }
                    else
                    {
                        <h4 class="text-success">$@Model.Price.ToString("0.00")</h4>
                    }

                    <p class="mt-3 text-muted">
                        @(Model.Description ?? "No description available.")
                    </p>

                    <div class="mt-4">
                        <div class="form-group mb-3">
                            <label for="quantity" class="form-label">Quantity:</label>
                            <input type="number"
                                   id="quantity"
                                   name="quantity"
                                   value="1"
                                   min="1"
                                   class="form-control"
                                   style="width: 120px;" />
                        </div>

                        <button onclick="addToCart(@Model.Id)" class="btn btn-primary btn-lg">
                            <i class="fas fa-shopping-cart"></i> Add to Cart
                        </button>

                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-outline-secondary btn-lg ms-2">
                            Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <h4>Product not found</h4>
            <p>The product you're looking for doesn't exist or has been removed.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Return to Home</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function addToCart(productId) {
            const quantity = document.getElementById('quantity')?.value || 1;

            fetch('/Home/AddToCart', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    productId: productId,
                    quantity: parseInt(quantity)
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Product added to cart successfully!');

                    // Update cart count if element exists
                    const cartBadge = document.getElementById('cartCount');
                    if (cartBadge) {
                        cartBadge.textContent = `Cart: ${data.count} items`;
                    }
                } else {
                    alert('Error adding product to cart');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error adding product to cart');
            });
        }
    </script>
}
