@* Views/Shared/_Newsletter.cshtml *@
<div class="newsletter-section bg-white border rounded p-5 my-5">
    <div class="row align-items-center">
        <div class="col-lg-6">
            <h4 class="fw-bold mb-2">Subscribe to our newsletter</h4>
            <p class="text-muted mb-0">Get the latest updates on new products and upcoming sales</p>
        </div>
        <div class="col-lg-6">
            <div class="input-group">
                <input type="email" class="form-control form-control-lg border-0 bg-light"
                       placeholder="Enter your email address">
                <button class="btn btn-primary px-4" type="button">Subscribe</button>
            </div>
        </div>
    </div>
</div>

<style>
    .newsletter-section {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }

        .newsletter-section .btn-primary {
            background-color: #0D6EFD;
            border: none;
        }

            .newsletter-section .btn-primary:hover {
                background-color: #0b5ed7;
            }
</style>