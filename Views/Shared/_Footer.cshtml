<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    /* Footer Container - Fixed Width to match Header */
    .site-footer {
        width: 1440px;
        height: 324px;
        margin: 0 auto;
        background: white;
        font-family: 'Inter', sans-serif;
    }

    .footer-main {
        padding: 40px 50px;
    }

    /* Brand Logo Styling */
    .brand-logo-box {
        background: #0D6EFD;
        width: 40px;
        height: 40px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Custom App Button Styling */
    .app-btn {
        background-color: #000;
        color: white;
        border-radius: 6px;
        padding: 5px 12px;
        display: flex;
        align-items: center;
        text-decoration: none;
        width: 135px; /* Fixed width for consistency */
        height: 42px;
        margin-bottom: 8px;
        transition: opacity 0.2s;
    }

    .app-btn:hover {
        color: white;
        opacity: 0.8;
    }

    .app-btn svg {
        margin-right: 8px;
        width: 20px;
        height: 20px;
    }

    .app-btn .btn-text {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
    }

    .app-btn .small-text {
        font-size: 8px;
        text-transform: uppercase;
        font-weight: 400;
    }

    .app-btn .large-text {
        font-size: 14px;
        font-weight: 600;
    }

    /* Column Links */
    .footer-link {
        color: #8B96A5;
        text-decoration: none;
        font-size: 16px;
        margin-bottom: 8px;
        display: block;
    }

    /* Bottom Copyright Bar */
    .footer-bottom {
        height: 68px;
        background: #F7FAFC;
        border-top: 1px solid #E3E8EE;
    }
</style>

