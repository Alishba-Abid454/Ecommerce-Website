<style>
    /* Main Header - Exact Dimensions 1440x86 */
    .ecommerce-header {
        width: 1440px;
        height: 86px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 20px;
        background: white;
        box-sizing: border-box;
        border-bottom: 1px solid #E3E8EE;
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    /* Brand Section */
    .brand-wrapper {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
    }

    .brand-logo-box {
        width: 44px;
        height: 44px;
        background: #0D6EFD;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .brand-text {
        font-size: 24px;
        font-weight: 700;
        color: #8CB7F5;
        letter-spacing: -0.5px;
    }

    /* Search Bar Layout - Adjusted height to fit 86px row */
    .search-form {
        display: flex;
        width: 665px;
        height: 40px;
        border: 2px solid #0D6EFD;
        border-radius: 8px;
        overflow: hidden;
    }

    .search-input {
        flex: 1;
        border: none;
        padding: 0 16px;
        font-size: 16px;
        outline: none;
        color: #1C1C1C;
    }

    .category-label {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 0 15px;
        border-left: 1px solid #E3E8EE;
        background: white;
        font-size: 15px;
        color: #1C1C1C;
        white-space: nowrap;
    }

    .search-button {
        background: #0D6EFD;
        color: white;
        border: none;
        padding: 0 24px;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
    }

    /* Actions Section */
    .actions-wrapper {
        display: flex;
        gap: 20px;
    }

    .action-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        color: #8B96A5;
    }

    .action-text {
        font-size: 12px;
        margin-top: 5px;
    }

    /* Razor-Safe Responsive Media Query */
    @@media (max-width: 1440px) {
        .ecommerce-header {
            width: 100%;
            padding: 0 20px;
        }
    }
</style>

<header class="ecommerce-header">
    <a href="/" class="brand-wrapper">
        <div class="brand-logo-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M16 11V7C16 4.79086 14.2091 3 12 3C9.79086 3 8 4.79086 8 7V11M5 9H19L20 21H4L5 9Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>
        <span class="brand-text">Brand</span>
    </a>

    <form action="/Search" method="get" class="search-form">
        <input type="text" name="q" class="search-input" placeholder="Search">
        <div class="category-label">
            <span>All category</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M2.5 4.5L6 8L9.5 4.5" stroke="#8B96A5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>
        <button type="submit" class="search-button">Search</button>
    </form>

    <div class="actions-wrapper">
        <a href="/Profile" class="action-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 21V19C20 17.8954 19.1046 17 18 17H6C4.89543 17 4 17.8954 4 19V21M16 7C16 9.20914 14.2091 11 12 11C9.79086 11 8 9.20914 8 7C8 4.79086 9.79086 3 12 3C14.2091 3 16 4.79086 16 7Z" />
            </svg>
            <span class="action-text">Profile</span>
        </a>
        <a href="/Messages" class="action-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15C21 15.5304 20.7893 16.0391 20.4142 16.4142C20.0391 16.7893 19.5304 17 19 17H7L3 21V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H19C19.5304 3 20.0391 3.21071 20.4142 3.58579C20.7893 3.96086 21 4.46957 21 5V15Z" />
            </svg>
            <span class="action-text">Message</span>
        </a>
        <a href="/Orders" class="action-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" />
            </svg>
            <span class="action-text">Orders</span>
        </a>
        <a href="/Cart" class="action-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 3H5L5.4 5M5.4 5H21L17 13H7L5.4 5ZM7 13L4.707 15.293C4.077 15.923 4.523 17 5.414 17H17M17 17C15.895 17 15 17.895 15 19C15 20.105 15.895 21 17 21C18.105 21 19 20.105 19 19C19 17.895 18.105 17 17 17ZM9 17C7.895 17 7 17.895 7 19C7 20.105 7.895 21 9 21C10.105 21 11 20.105 11 19C11 17.895 10.105 17 9 17Z" />
            </svg>
            <span class="action-text">My cart</span>
        </a>
    </div>
</header>