@model EcommerceFullstackDesign.Models.ProductViewModel

<div class="row">
    <div class="col-md-6">
        <img src="@Model.ImageUrl" class="img-fluid" alt="@Model.Name">
    </div>
    <div class="col-md-6">
        <h4>@Model.Name</h4>

        @if (!string.IsNullOrEmpty(Model.Brand))
        {
            <p class="text-muted">Brand: @Model.Brand</p>
        }

        <div class="mb-3">
            @if (Model.OldPrice.HasValue)
            {
                <span class="h3 text-danger">$@Model.Price.ToString("F2")</span>
                <del class="text-muted ms-2">$@Model.OldPrice.Value.ToString("F2")</del>
            }
            else
            {
                <span class="h3 text-primary">$@Model.Price.ToString("F2")</span>
            }
        </div>

        <div class="text-warning mb-3">
            @for (int i = 1; i <= 5; i++)
            {
                if (i <= Math.Floor(Model.Rating))
                {
                    <i class="fas fa-star"></i>
                }
                else if (i - 0.5 <= Model.Rating)
                {
                    <i class="fas fa-star-half-alt"></i>
                }
                else
                {
                    <i class="far fa-star"></i>
                }
            }
            <span class="text-muted ms-2">(@Model.ReviewCount reviews)</span>
        </div>

        <p class="text-muted">@(Model.Description?.Length > 100 ? Model.Description.Substring(0, 100) + "..." : Model.Description)</p>

        <div class="mb-3">
            @if (Model.IsVerified)
            {
                <span class="badge bg-info me-2">Verified</span>
            }
            @if (Model.FreeShipping)
            {
                <span class="badge bg-success">Free Shipping</span>
            }
        </div>

        <div class="d-flex gap-2">
            <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-outline-primary">View Details</a>
            <button class="btn btn-primary add-to-cart-btn" data-id="@Model.Id">
                <i class="fas fa-cart-plus"></i> Add to Cart
            </button>
        </div>
    </div>
</div>






