



@* @{
    ViewData["Title"] = "Products";
}

<div class="container py-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb small text-muted">
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Home</a></li>
            <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">Clothings</a></li>
            <li class="breadcrumb-item active">Summer clothing</li>
        </ol>
    </nav>

    <div class="row">
        <aside class="col-lg-3 d-none d-lg-block">
            <div class="accordion border-top" id="filterAccordion">
                <div class="filter-group py-3 border-bottom">
                    <h6 class="fw-bold mb-3">Category <i class="fa fa-chevron-up float-end small mt-1 text-muted"></i></h6>
                    <ul class="list-unstyled mb-0 text-muted small">
                        <li class="mb-2">Mobile accessory</li>
                        <li class="mb-2">Electronics</li>
                        <li class="mb-2">Smartphones</li>
                        <li class="text-primary cursor-pointer">See all</li>
                    </ul>
                </div>

                <div class="filter-group py-3 border-bottom">
                    <h6 class="fw-bold mb-3">Brands <i class="fa fa-chevron-up float-end small mt-1 text-muted"></i></h6>
                    @foreach (var brand in new[] { "Samsung", "Apple", "Huawei", "Pocco", "Lenovo" })
                    {
                        <div class="form-check mb-2 small text-muted">
                            <input class="form-check-input" type="checkbox">
                            <label class="form-check-label">@brand</label>
                        </div>
                    }
                    <span class="text-primary small cursor-pointer">See all</span>
                </div>
                <div class="filter-group py-3 border-top">
                    <h6 class="fw-bold d-flex justify-content-between align-items-center cursor-pointer">
                        Features <i class="fa fa-chevron-up small text-muted"></i>
                    </h6>
                    <div class="mt-3">
                        <div class="form-check mb-2 small text-muted">
                            <input class="form-check-input" type="checkbox" id="feat1">
                            <label class="form-check-label" for="feat1">Metallic</label>
                        </div>
                        <div class="form-check mb-2 small text-muted">
                            <input class="form-check-input" type="checkbox" id="feat2">
                            <label class="form-check-label" for="feat2">8GB Ram</label>
                        </div>
                        <div class="form-check mb-2 small text-muted">
                            <input class="form-check-input" type="checkbox" id="feat3">
                            <label class="form-check-label" for="feat3">Super power</label>
                        </div>
                        <span class="text-primary small cursor-pointer">See all</span>
                    </div>
                </div>
                <div class="filter-group py-3 border-bottom">
                    <h6 class="fw-bold mb-3">Price range <i class="fa fa-chevron-up float-end small mt-1 text-muted"></i></h6>
                    <input type="range" class="form-range" min="0" max="1000">
                    <div class="d-flex gap-2 mt-2">
                        <div class="col-6">
                            <label class="small text-muted">Min</label>
                            <input type="number" class="form-control form-control-sm" placeholder="0">
                        </div>
                        <div class="col-6">
                            <label class="small text-muted">Max</label>
                            <input type="number" class="form-control form-control-sm" placeholder="999999">
                        </div>
                    </div>
                    <button class="btn btn-white border w-100 btn-sm mt-3 text-primary shadow-sm">Apply</button>
                </div>
                <div class="filter-group py-3 border-top">
                    <h6 class="fw-bold d-flex justify-content-between align-items-center cursor-pointer">
                        Condition <i class="fa fa-chevron-up small text-muted"></i>
                    </h6>
                    <div class="mt-3">
                        <div class="form-check mb-2 small text-muted">
                            <input class="form-check-input" type="radio" name="cond" checked>
                            <label class="form-check-label">Any</label>
                        </div>
                        <div class="form-check mb-2 small text-muted">
                            <input class="form-check-input" type="radio" name="cond">
                            <label class="form-check-label">Refurbished</label>
                        </div>
                    </div>
                </div>

                <div class="filter-group py-3 border-top">
                    <h6 class="fw-bold d-flex justify-content-between align-items-center cursor-pointer">
                        Ratings <i class="fa fa-chevron-up small text-muted"></i>
                    </h6>
                    <div class="mt-3">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox">
                            <label class="form-check-label text-warning small">
                                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            </label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox">
                            <label class="form-check-label text-warning small">
                                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="far fa-star text-muted"></i>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

        <main class="col-lg-9">
            <div class="card border border-light-subtle shadow-none rounded-3 p-3 mb-3">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span class="small">12,911 items in <strong class="fw-bold">Mobile accessory</strong></span>
                    <div class="d-flex align-items-center gap-3">
                        <div class="form-check mb-0 small">
                            <input class="form-check-input" type="checkbox" checked>
                            <label class="form-check-label">Verified only</label>
                        </div>
                        <select class="form-select form-select-sm w-auto shadow-none">
                            <option>Featured</option>
                        </select>
                        <div class="btn-group shadow-none border rounded overflow-hidden">
                            <button class="btn btn-light border-0"><i class="fa fa-th"></i></button>
                            <button class="btn btn-white border-0 bg-secondary-subtle"><i class="fa fa-bars text-dark"></i></button>
                        </div>
                    </div>
                </div>
            </div>

            @for (int i = 0; i < 6; i++)
            {
                <div class="card border border-light-subtle shadow-none rounded-3 p-3 mb-3">
                    <div class="row align-items-center">
                        <div class="col-md-3 text-center mb-3 mb-md-0">
                            <img src="/images/product-@(i).png" class="img-fluid" style="max-height: 180px;">
                        </div>
                        <div class="col-md-7">
                            <div class="d-flex justify-content-between">
                                <h6 class="mb-1 text-dark">Canon Cmera EOS 2000, Black 10x zoom</h6>
                                <button class="btn btn-sm btn-light border d-md-none"><i class="fa fa-heart-o"></i></button>
                            </div>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <span class="fw-bold h5 mb-0">$998.00</span>
                                <del class="text-muted small">$1128.00</del>
                            </div>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="text-warning small">
                                    <i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa-solid fa-star-half-stroke"></i>
                                    <span class="ms-1">7.5</span>
                                </div>
                                <span class="text-muted small">• 154 orders</span>
                                <span class="text-success small fw-bold">• Free Shipping</span>
                            </div>
                            <p class="text-muted small mb-3">Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>
                            <a href="#" class="text-primary text-decoration-none fw-bold small">View details</a>
                        </div>
                        <div class="col-md-2 text-end d-none d-md-block">
                            <button class="btn btn-white border text-primary shadow-sm rounded-3 p-2"><i class="fa-regular fa-heart"></i></button>
                        </div>
                    </div>
                </div>
            }

            <nav class="d-flex justify-content-end mt-4">
                <ul class="pagination pagination-sm">
                    <li class="page-item"><a class="page-link text-dark" href="#"><i class="fa fa-chevron-left"></i></a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link text-dark" href="#">2</a></li>
                    <li class="page-item"><a class="page-link text-dark" href="#">3</a></li>
                    <li class="page-item"><a class="page-link text-dark" href="#"><i class="fa fa-chevron-right"></i></a></li>
                </ul>
            </nav>
        </main>
    </div>
</div>

@await Html.PartialAsync("_Newsletter") *@