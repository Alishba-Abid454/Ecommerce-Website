 <div class="card h-100 border-0 shadow-none product-card">
    <div class="text-center p-3">
        <img src="/images/phone.png" class="img-fluid" style="height: 180px; object-fit: contain;" alt="Product">
    </div>

    <div class="card-body border-top p-3">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <span class="fw-bold d-block" style="font-size: 18px; color: #1C1C1C;">$99.50</span>
                <span class="text-muted small text-decoration-line-through">$1128.00</span>
            </div>
            <button class="btn btn-heart-box">
                <i class="fa fa-heart-o"></i>
            </button>
        </div>

        <div class="text-warning small my-2">
            <i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star-half-o"></i>
            <span class="text-muted ms-1">7.5</span>
        </div>

        <p class="text-secondary small mb-1" style="line-height: 1.3;">GoPro HERO6 Black 4K Action Camera - Black</p>
        <div class="text-muted small">Camera - Black</div>
    </div>
</div>



