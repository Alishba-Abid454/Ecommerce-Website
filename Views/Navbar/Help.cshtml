@{
    ViewData["Title"] = "Help Center";
}

<div class="container py-4">
    <!-- Header -->
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">How can we help you?</h1>
        <p class="text-muted">Find answers to your questions below</p>
    </div>

    <!-- Search Bar -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" class="form-control form-control-lg" placeholder="Search for help...">
                <button class="btn btn-primary" type="button">Search</button>
            </div>
        </div>
    </div>

    <!-- Help Categories -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <i class="fa-regular fa-circle-question fa-3x text-primary mb-3"></i>
                <h5>FAQ</h5>
                <p class="text-muted">Frequently asked questions</p>
                <a href="@Url.Action("FAQ", "Navbar")" class="btn btn-outline-primary mt-2">View FAQs</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <i class="fa-regular fa-envelope fa-3x text-primary mb-3"></i>
                <h5>Contact Us</h5>
                <p class="text-muted">Get in touch with our team</p>
                <a href="@Url.Action("Contact", "Navbar")" class="btn btn-outline-primary mt-2">Contact</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm text-center p-4">
                <i class="fa-regular fa-file-lines fa-3x text-primary mb-3"></i>
                <h5>About Us</h5>
                <p class="text-muted">Learn more about our company</p>
                <a href="@Url.Action("About", "Navbar")" class="btn btn-outline-primary mt-2">About</a>
            </div>
        </div>
    </div>

    <!-- Common Topics -->
    <h4 class="fw-bold mb-4">Common Topics</h4>
    <div class="row g-3">
        <div class="col-md-6">
            <div class="list-group">
                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    How to track my order?
                    <i class="fa-solid fa-chevron-right text-muted"></i>
                </a>
                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    What is your return policy?
                    <i class="fa-solid fa-chevron-right text-muted"></i>
                </a>
                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    How long does shipping take?
                    <i class="fa-solid fa-chevron-right text-muted"></i>
                </a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="list-group">
                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    Payment methods accepted
                    <i class="fa-solid fa-chevron-right text-muted"></i>
                </a>
                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    How to create an account?
                    <i class="fa-solid fa-chevron-right text-muted"></i>
                </a>
                <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    Discount codes and coupons
                    <i class="fa-solid fa-chevron-right text-muted"></i>
                </a>
            </div>
        </div>
    </div>
</div>