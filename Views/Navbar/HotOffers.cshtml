@using EcommerceFullstackDesign.Models
@model List<NavbarProductViewModel>
@{
    ViewData["Title"] = ViewBag.Title ?? "Hot Offers";

    // Helper function for image path
    string GetImageUrl(string? imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl))
            return "/Image/default.png";

        // Normalize path to use /Image/ (capital I)
        if (imageUrl.StartsWith("/image/"))
            return "/Image/" + imageUrl.Substring(7);

        return imageUrl;
    }
}

<div class="container py-4">
    <!-- Page Header -->
    <div class="mb-4">
        <h1 class="display-6 fw-bold">@ViewBag.Title</h1>
        <p class="text-muted">@ViewBag.Description</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <!-- Hot Offers Grid - Exactly like Deals and Offers style -->
        <div class="row g-4">
            @foreach (var product in Model)
            {
                <div class="col-lg-3 col-md-4 col-6">
                    <div class="border rounded bg-white overflow-hidden h-100 d-flex flex-column">
                        <div class="p-4 text-center flex-grow-1">
                            <a href="@Url.Action("ProductDetails", "Home", new { id = product.Id })" class="text-decoration-none text-dark">
                                <img src="@GetImageUrl(product.ImageUrl)"
                                     height="120"
                                     alt="@product.Name"
                                     style="object-fit: contain; max-width: 100%;" />
                                <p class="mt-3 mb-1 fw-semibold">@product.Name</p>

                                @if (product.DiscountPrice.HasValue)
                                {
                                    var discountPercent = (int)((product.Price - product.DiscountPrice.Value) / product.Price * 100);
                                    <div class="mb-2">
                                        <span class="badge bg-danger rounded-pill">-@discountPercent%</span>
                                    </div>
                                    <div>
                                        <span class="text-muted text-decoration-line-through small">$@product.Price.ToString("F2")</span>
                                        <span class="text-danger fw-bold ms-2">$@product.DiscountPrice.Value.ToString("F2")</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="fw-bold">$@product.Price.ToString("F2")</span>
                                }
                            </a>
                        </div>
                        <div class="p-3 pt-0">
                            <button class="btn btn-sm btn-outline-primary w-100 add-to-cart"
                                    onclick="addToCartAndRedirect(@product.Id, 1)">
                                <i class="fa-solid fa-cart-plus me-1"></i>Add to Cart
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fa-regular fa-face-frown fa-4x text-muted mb-3"></i>
            <h4>No offers available</h4>
            <p class="text-muted">Check back later for new deals!</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Go to Home</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function addToCartAndRedirect(productId, quantity) {
            fetch('/Cart/AddToCart', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `productId=${productId}&quantity=${quantity}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.href = '/Cart/Index';
                } else {
                    alert('Error adding product to cart');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error adding product to cart');
            });
        }
    </script>
}