@{
    ViewData["Title"] = "About Us";
}

<div class="container py-4">
    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">About Our Company</h1>
        <p class="lead text-muted">We're on a mission to provide the best shopping experience</p>
    </div>

    <!-- Our Story -->
    <div class="row g-5 mb-5 align-items-center">
        <div class="col-md-6">
            <img src="~/images/about-story.jpg" class="img-fluid rounded-3 shadow" alt="Our Story">
        </div>
        <div class="col-md-6">
            <h2 class="fw-bold mb-4">Our Story</h2>
            <p class="text-muted mb-4">Founded in 2020, EcommerceFullstackDesign started with a simple idea: to make online shopping easier, faster, and more enjoyable for everyone. What began as a small startup has grown into a trusted destination for millions of customers worldwide.</p>
            <p class="text-muted">We believe in quality products, exceptional service, and building lasting relationships with our customers. Our team works tirelessly to bring you the best selection of products at competitive prices.</p>
            <div class="row g-3 mt-4">
                <div class="col-4 text-center">
                    <h3 class="fw-bold text-primary">10K+</h3>
                    <p class="text-muted">Products</p>
                </div>
                <div class="col-4 text-center">
                    <h3 class="fw-bold text-primary">50K+</h3>
                    <p class="text-muted">Happy Customers</p>
                </div>
                <div class="col-4 text-center">
                    <h3 class="fw-bold text-primary">24/7</h3>
                    <p class="text-muted">Support</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Our Values -->
    <div class="row g-4 mb-5">
        <div class="col-12 text-center mb-4">
            <h2 class="fw-bold">Our Core Values</h2>
            <p class="text-muted">What drives us every day</p>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-block mx-auto mb-3" style="width: 80px; height: 80px;">
                    <i class="fa-regular fa-heart text-primary fa-2x mt-3"></i>
                </div>
                <h5 class="fw-bold">Customer First</h5>
                <p class="text-muted">We put our customers at the heart of everything we do.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-block mx-auto mb-3" style="width: 80px; height: 80px;">
                    <i class="fa-regular fa-star text-primary fa-2x mt-3"></i>
                </div>
                <h5 class="fw-bold">Quality First</h5>
                <p class="text-muted">We never compromise on quality and authenticity.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-block mx-auto mb-3" style="width: 80px; height: 80px;">
                    <i class="fa-regular fa-handshake text-primary fa-2x mt-3"></i>
                </div>
                <h5 class="fw-bold">Trust & Integrity</h5>
                <p class="text-muted">Building trust through transparency and honesty.</p>
            </div>
        </div>
    </div>

    <!-- Team Section -->
    <div class="row g-4 mb-5">
        <div class="col-12 text-center mb-4">
            <h2 class="fw-bold">Meet Our Team</h2>
            <p class="text-muted">The people behind the scenes</p>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm text-center">
                <img src="~/images/team1.jpg" class="card-img-top" alt="Team Member">
                <div class="card-body">
                    <h6 class="fw-bold">John Doe</h6>
                    <p class="text-muted small">CEO & Founder</p>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm text-center">
                <img src="~/images/team2.jpg" class="card-img-top" alt="Team Member">
                <div class="card-body">
                    <h6 class="fw-bold">Jane Smith</h6>
                    <p class="text-muted small">Head of Operations</p>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm text-center">
                <img src="~/images/team3.jpg" class="card-img-top" alt="Team Member">
                <div class="card-body">
                    <h6 class="fw-bold">Mike Johnson</h6>
                    <p class="text-muted small">Technical Lead</p>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm text-center">
                <img src="~/images/team4.jpg" class="card-img-top" alt="Team Member">
                <div class="card-body">
                    <h6 class="fw-bold">Sarah Williams</h6>
                    <p class="text-muted small">Customer Support</p>
                </div>
            </div>
        </div>
    </div>
</div>