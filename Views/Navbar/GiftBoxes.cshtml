@using EcommerceFullstackDesign.Models
@model List<NavbarGiftViewModel>
@{
    ViewData["Title"] = ViewBag.Title ?? "Gift Boxes";
}

<div class="container py-4">
    <!-- Page Header -->
    <div class="mb-4 text-center">
        <h1 class="display-6 fw-bold">@ViewBag.Title</h1>
        <p class="text-muted">@ViewBag.Description</p>
        <img src="~/images/gift-banner.jpg" class="img-fluid rounded-3 mb-4" alt="Gifts" style="max-height: 200px; width: 100%; object-fit: cover;">
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var gift in Model)
            {
                <div class="col-lg-3 col-md-4 col-6">
                    <div class="card h-100 border-0 shadow-sm product-card">
                        <div class="position-relative">
                            <a href="@Url.Action("ProductDetails", "Home", new { id = gift.Id })">
                                <img src="@(gift.ImageUrl ?? "/images/default.png")"
                                     class="card-img-top p-3"
                                     alt="@gift.Name"
                                     style="height: 200px; object-fit: contain;">
                            </a>
                            <span class="position-absolute top-0 end-0 badge bg-success m-2">Gift</span>
                        </div>
                        <div class="card-body">
                            <a href="@Url.Action("ProductDetails", "Home", new { id = gift.Id })" class="text-decoration-none text-dark">
                                <h6 class="card-title">@gift.Name</h6>
                                <p class="text-muted small">@gift.Description</p>
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="fw-bold h5 mb-0">$@gift.Price.ToString("F2")</span>
                                </div>
                                <small class="text-success"><i class="fa-regular fa-gift me-1"></i> @gift.Items items</small>
                            </a>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3">
                            <button class="btn btn-sm btn-outline-primary w-100 add-to-cart"
                                    onclick="addToCartAndRedirect(@gift.Id, 1)">
                                <i class="fa-solid fa-cart-plus"></i> Add to Cart
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fa-regular fa-gift fa-4x text-muted mb-3"></i>
            <h4>No gift items available</h4>
            <p class="text-muted">Check back later for new gift ideas!</p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Go to Home</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function addToCartAndRedirect(productId, quantity) {
            fetch('/Cart/AddToCart', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                },
                body: `productId=${productId}&quantity=${quantity}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.href = '/Cart/Index';
                } else {
                    alert('Error adding product to cart');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error adding product to cart');
            });
        }
    </script>
}